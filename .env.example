# DeepSeek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选：如果使用其他 LLM 提供商，可以取消注释以下配置
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：Pinecone 向量数据库配置（用于 RAG 功能）
# PINECONE_API_KEY=your_pinecone_api_key
# PINECONE_ENVIRONMENT=your_environment
# PINECONE_INDEX_NAME=elderly-care-index

# PageIndex RAG（可选）
# 1. 先用 `python code/rag_agent_cli.py build ...` 生成索引
# 2. 再开启下方开关，将知识检索接入报告生成流程
RAG_ENABLED=false
RAG_INDEX_PATH=data/rag_indexes/default_index.json
RAG_TOP_K=3
# RAG_MODEL=gpt-4o-2024-11-20

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=True

# 数据库配置（SQLite）
DB_PATH=data/users.db

# 日志配置
LOG_LEVEL=INFO
